# Supabase — get these from your Supabase project dashboard under Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key

# WhatsApp — international format without + or spaces (Nigeria: 234XXXXXXXXXX)
NEXT_PUBLIC_WHATSAPP_NUMBER=2348012345678

# UploadThing — get this from your UploadThing project dashboard under Settings > API Keys
UPLOADTHING_TOKEN=your-uploadthing-token

# Neon (Drizzle) — get from neon.tech project dashboard
# Use the POOLED connection string for application queries
DATABASE_URL=postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# UNPOOLED connection for migrations (drizzle-kit push/migrate, pg_restore)
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require